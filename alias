alias l='ls -al'
alias sudo='sudo env "PATH=$PATH" '
if command -v navi > /dev/null; then
  navikv() {
    export NAVI_KV_SEARCH=$2
    navi --query "$1" --best-match
  }
  navialias() {
    navi --query "alias :: $1" --best-match
  }
  alias clip='navialias clip'
  alias pasteclip='navialias pasteclip'
  alias np='navialias np'
  alias ncp='navialias ncp'
  alias tt='navialias tt'
  alias setproxy='navialias setproxy'
  alias unsetproxy='navialias unsetproxy'
  alias searchlink='navikv "kvs searchlink"'
  alias sl='searchlink'
  alias copylink='searchlink | clip'
  alias cl='copylink'
  alias n='navi'
  alias searchvalue='navi --query "kvs searchvalue" --best-match'
  alias sv='searchvalue'
  alias copyvalue='searchvalue | clip'
  alias cv='copyvalue'
fi
